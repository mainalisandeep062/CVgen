#!/bin/bash
# .env.example – Copy to .env and fill in your values


# App metadata
APP_NAME=CVgen

# Database (required)
DATABASE_URL=jdbc:postgresql://localhost:5432/cvgen
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# JWT Configuration (required — no default, fails fast if unset)
JWT_SECRET=your-production-secret-at-least-64-chars-long
JWT_ISSUER=cvgen
JWT_EXPIRATION=PT2H
JWT_CLOCK_SKEW=PT2M

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_SCOPES=openid,profile,email

# GitHub OAuth2
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_OAUTH_SCOPES=read:user,user:email

# LinkedIn OAuth2
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_AUTHORIZATION_URI=https://www.linkedin.com/oauth/v2/authorization
LINKEDIN_TOKEN_URI=https://www.linkedin.com/oauth/v2/accessToken
LINKEDIN_USER_INFO_URI=https://api.linkedin.com/v2/userinfo
LINKEDIN_USER_NAME_ATTRIBUTE=sub
LINKEDIN_OAUTH_SCOPES=openid,profile,email

# OAuth2 Redirect URIs
OAUTH2_REDIRECT_URI=http://localhost:3000/oauth2/redirect
OAUTH2_SUCCESS_REDIRECT_URI=http://localhost:3000/auth/success
OAUTH2_FAILURE_REDIRECT_URI=http://localhost:3000/auth/failure
OAUTH2_AUTHORIZED_REDIRECT_URIS=http://localhost:3000/oauth2/redirect,http://localhost:3000/auth/success
OAUTH2_ACCESS_TOKEN_COOKIE_NAME=cvgen_access_token
OAUTH2_BEARER_PREFIX=Bearer
OAUTH2_DEFAULT_ROLE=ROLE_USER
OAUTH2_GOOGLE_PROVIDER_ID=google
OAUTH2_GITHUB_PROVIDER_ID=github
OAUTH2_LINKEDIN_PROVIDER_ID=linkedin
OAUTH2_SECURE_SAMESITE=None
OAUTH2_INSECURE_SAMESITE=Lax
OAUTH2_UNSUPPORTED_PROVIDER_ERROR_CODE=unsupported_oauth2_provider
OAUTH2_FAILURE_ERROR_CODE=oauth2_authentication_failed
APP_SECURITY_UNAUTHORIZED_MESSAGE=Unauthorized
APP_SECURITY_FORBIDDEN_MESSAGE=Forbidden
APP_SECURITY_LOGOUT_URL=/logout

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Cache-Control,Content-Type,X-Requested-With
CORS_EXPOSED_HEADERS=Authorization
CORS_ALLOW_CREDENTIALS=true

# Async/Web
ASYNC_CORE_POOL_SIZE=4
ASYNC_MAX_POOL_SIZE=8
ASYNC_QUEUE_CAPACITY=250
ASYNC_THREAD_NAME_PREFIX=cvgen-async-
WEB_ASSETS_CACHE_PERIOD=3600