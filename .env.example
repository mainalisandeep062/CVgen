#!/bin/bash
# .env.example – Copy to .env and fill in your OAuth2 credentials

# JWT Configuration
JWT_SECRET=your-production-secret-at-least-64-chars-long
JWT_ISSUER=cvgen
JWT_EXPIRATION=PT2H
JWT_CLOCK_SKEW=PT2M

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth2
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# LinkedIn OAuth2
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_AUTHORIZATION_URI=https://www.linkedin.com/oauth/v2/authorization
LINKEDIN_TOKEN_URI=https://www.linkedin.com/oauth/v2/accessToken
LINKEDIN_USER_INFO_URI=https://api.linkedin.com/v2/userinfo

# OAuth2 Redirect URIs
OAUTH2_REDIRECT_URI=http://localhost:3000/oauth2/redirect
OAUTH2_SUCCESS_REDIRECT_URI=http://localhost:3000/auth/success
OAUTH2_FAILURE_REDIRECT_URI=http://localhost:3000/auth/failure

# CORS Configuration
CORS_ALLOWED_ORIGIN_1=http://localhost:3000
CORS_ALLOWED_ORIGIN_2=http://127.0.0.1:3000

