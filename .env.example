# Database (required)
DATABASE_URL=jdbc:postgresql://localhost:5432/cvgen
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# JWT (required — no default, fails fast if unset)
JWT_SECRET=change-me-in-production-min-256-bits
JWT_ISSUER=cvgen
JWT_EXPIRATION=PT2H
JWT_CLOCK_SKEW=PT2M

# OAuth2 (optional for local dev — configure for OAuth login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_AUTHORIZATION_URI=https://www.linkedin.com/oauth/v2/authorization
LINKEDIN_TOKEN_URI=https://www.linkedin.com/oauth/v2/accessToken
LINKEDIN_USER_INFO_URI=https://api.linkedin.com/v2/userinfo

# CORS (optional — defaults to localhost:3000)
CORS_ALLOWED_ORIGIN_1=http://localhost:3000
CORS_ALLOWED_ORIGIN_2=http://127.0.0.1:3000

# Frontend redirect URIs (optional — defaults shown)
OAUTH2_REDIRECT_URI=http://localhost:3000/oauth2/redirect
OAUTH2_SUCCESS_REDIRECT_URI=http://localhost:3000/auth/success
OAUTH2_FAILURE_REDIRECT_URI=http://localhost:3000/auth/failure
