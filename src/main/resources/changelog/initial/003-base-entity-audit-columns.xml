<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.29.xsd">

    <!--
        BaseEntity gives every entity an updated_at audit column.
        users already has one; the remaining tables get it here, backfilled from created_at.
    -->
    <changeSet id="003-base-entity-audit-columns" author="sandeep mainali">

        <addColumn tableName="user_identities">
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <update tableName="user_identities">
            <column name="updated_at" valueComputed="created_at"/>
        </update>

        <addColumn tableName="otp_codes">
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <update tableName="otp_codes">
            <column name="updated_at" valueComputed="created_at"/>
        </update>

        <addColumn tableName="trusted_devices">
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <update tableName="trusted_devices">
            <column name="updated_at" valueComputed="created_at"/>
        </update>

        <rollback>
            <dropColumn tableName="user_identities" columnName="updated_at"/>
            <dropColumn tableName="otp_codes" columnName="updated_at"/>
            <dropColumn tableName="trusted_devices" columnName="updated_at"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
